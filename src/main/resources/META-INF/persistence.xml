<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
    version="3.0">

    <persistence-unit name="sparkfiPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>org.sparkfi.model.User</class>
        <class>org.sparkfi.model.Course</class>
        <class>org.sparkfi.model.UserProgress</class>
        <class>org.sparkfi.model.LoginSession</class>
        <class>org.sparkfi.model.Challenge</class>
        <class>org.sparkfi.model.CommunityPost</class>
        <class>org.sparkfi.model.UserAchievement</class>
        <class>org.sparkfi.model.UserSettings</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver" />

            <!-- Las credenciales reales se cargan desde variables de entorno en JpaUtil -->
            <!-- Ejemplo de URL JDBC: jdbc:postgresql://HOST:5432/DATABASE?sslmode=require -->

            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect" />
            <property name="hibernate.hbm2ddl.auto" value="update" />
            <property name="hibernate.show_sql" value="true" />
            <property name="hibernate.format_sql" value="true" />
        </properties>
    </persistence-unit>
</persistence>
